  "decision_semantics": {
    "gate_vocabulary": {
      "PASS": {"release": "allowed", "meaning": "clean pass"},
      "WARN": {"release": "allowed", "meaning": "must be in evidence bundle"},
      "CONDITIONAL_PASS": {"release": "allowed only with explicit risk acceptance reference", "meaning": "approved with documented exception"},
      "FAIL": {"release": "blocked", "meaning": "release blocked"},
      "BLOCKED": {"release": "blocked", "meaning": "evidence or process missing"},
      "STALE": {"release": "blocked", "meaning": "evidence outdated, re-run required"},
      "STRATEGY_READY": {"release": "n/a", "meaning": "plan or design phase only (not a release decision)"}
    },
    "per_subsystem_verdicts": {
      "appsec": ["PASS", "WARN", "CONDITIONAL_PASS", "FAIL", "BLOCKED", "STALE"],
      "qa": ["PASS", "WARN", "FAIL", "BLOCKED", "STALE"],
      "uiux": ["PASS", "WARN", "FAIL", "STRATEGY_READY"],
      "discoverability": ["PASS", "WARN", "FAIL", "BLOCKED", "STALE"],
      "gsd": ["PASS", "FAIL"]
    },
    "notes": "Canonical vocabulary from CANONICALS.md §3. Subsystem verdict sets are subsets of full vocabulary; QA omits CONDITIONAL_PASS by design (risk acceptance lives in AppSec layer)."
  },

