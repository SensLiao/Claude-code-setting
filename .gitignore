# ============================================================
# Claude Code 配置仓库 — .gitignore 黑名单
# 防止 secrets / 个人数据 / 缓存 / 二进制误传到 GitHub
# ============================================================

# === 🔴 SECRETS / CREDENTIALS（绝对不能上传） ===
.credentials.json
*.credentials
*credentials*
.env
.env.*
!.env.example
tokens/
oauth/
*token*
# design-token-pipeline 是合法 skill（非 secret），豁免上面的 *token* 误伤
!skills/design-token-pipeline/
!skills/design-token-pipeline/**
*.pem
*.key
*.p12

# === 🔴 含 OAuth 的 settings（只保留 settings.example.json） ===
settings.json
settings.local.json
.last-cleanup
.gsd-profile

# === 🟡 本地 per-machine 产物（用户决定不上）===
# profiles/ = 本机 hook 接线记录（export-profile 输出），因机而异，不分发。
# 注：claude-config.js + wire-manifest.json 已改回纳入分发（2026-06-23）——安装器需随 repo 到新设备。
profiles/

# === 🟡 个人数据 / 对话历史（用户决定不上） ===
# 本地工作账本(§0.7 进度 ledger）— 仅追踪个人进度，不上仓库
.goals/
memory/
projects/
sessions/
tasks/
jobs/
teams/
plans/
metrics/
session-data/
session-env/
shell-snapshots/
paste-cache/

# === 🟡 缓存 / 状态（每台机器各自生成） ===
cache/
*-cache.json
mcp-health-cache.json
mcp-needs-auth-cache.json
stats-cache.json
file-history/
gsd-migration-journal/
daemon/
daemon.log

# === 🟡 日志 / 运行时产物 ===
*.log
*.jsonl
bash-commands.log
cost-tracker.log
history.jsonl

# === 🟡 大体积二进制 / 下载物 / 独立 repo（精确排除，保留同目录下的配置源码）===
# 说明：不再整目录排除 tools/ mcp-servers/ plugins/ —— 它们含必须随配置迁移的
#       自写工具源码 / 自建 MCP server 源码 / 装机清单。只排除其中可重装或本机生成的部分。
homunculus/

# tools/ : 保留 ccswitch-guard / docs-drift / hooks / relocation-integrity 脚本；
#          排除独立 git 项目 gstack、Python 缓存、本机运行时快照
tools/gstack/
tools/**/__pycache__/
tools/**/*.snapshot.json

# mcp-servers/ : 保留自建 server 源码(package.json + src/dist)；排除可重装依赖
mcp-servers/**/node_modules/

# plugins/ : 保留装机清单(installed_plugins.json / known_marketplaces.json / blocklist.json)；
#            排除下载的 marketplace 仓库与缓存（新机器用 /plugin 重新拉取）
plugins/cache/
plugins/marketplaces/
plugins/data/
plugins/*-cache.json

# === 🟡 旧备份 ===
backups/
_backup-*/
_backup-*

# === 🟡 机器特定的安装状态文件 ===
gsd-install-state.json
gsd-file-manifest.json
ecc/install-state.json
.last-update-result.json
plugins/.last_inuse_sweep

# === 🟡 其它工具的可重装/缓存目录（2026-06-23 audit）===
# .opencode = npm 包 ecc-universal（可 npm i 重装）; .agents = ECC 上游 skills（可重装）
# 手写的 .cursor / .codex / .gemini 桥接配置则保留上传（不在此忽略，已纳入仓库）
.opencode/
.agents/
chrome/
image-cache/

# === 🟡 OS / 编辑器噪声 ===
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*~

# === 🟡 Python 缓存 ===
__pycache__/
*.pyc
*.pyo

# === 🟡 Node 缓存 ===
node_modules/

# === 🟡 工作临时文件 ===
.sanitize-tmp.py
*.tmp
*.bak

# extra hygiene (2026-06-05 re-export)
*.bak-*
skills/arch-viz-workspace/

# skill 内从上游 clone 带来的 git 残留（统一不传，2026-06-06）
skills/**/.git/
skills/**/.gitignore
skills/**/.gitattributes
skills/**/.github/

# skill 运行时产物 / 状态（原 skill 子 .gitignore 规则提升至根，删子 .gitignore 后仍不传）
skills/**/state/checkpoint.json
skills/**/state/log.md
skills/**/output/
skills/**/ui-lab/
skills/**/audits/manifest.json.bak
skills/**/*.local
