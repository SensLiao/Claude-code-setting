{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude.local/schemas/hook-registry.schema.json",
  "title": "Hook Registry",
  "description": "JSON Schema (draft-07) for manifests/hook-registry.json. Rewritten 2026-06-10 to match the live `categories`-wrapped shape (the previous draft described an obsolete top-level global_live/project_installed/library_modules layout). The registry is the single source of truth for hook enumeration, triggers, and per-subsystem install metadata. Per CANONICALS.md D3, subsystem hooks are project-installed-only; only the global_live set fires on every session. Each hook entry carries a `trigger` (a Claude Code hook phase string such as 'SessionStart' / 'Stop' / 'PreToolUse(Skill)' / 'PreToolUse(Bash)', OR an array of such strings for dual-mode hooks) and a `purpose`. The installer that consumes this registry is orchestrator-runtime/shared/install-subsystem-hooks.js.",
  "type": "object",
  "required": [
    "schema_version",
    "categories"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Relative pointer to this schema file."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_date": {
      "type": "string",
      "format": "date"
    },
    "generated_by": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "categories": {
      "type": "object",
      "description": "The 5-category taxonomy of harness hooks.",
      "required": [
        "global_live",
        "project_installed",
        "library_modules",
        "dormant_opt_in",
        "deprecated"
      ],
      "additionalProperties": false,
      "properties": {
        "global_live": { "$ref": "#/$defs/GlobalLiveCategory" },
        "project_installed": { "$ref": "#/$defs/ProjectInstalledCategory" },
        "library_modules": { "$ref": "#/$defs/LibraryModulesCategory" },
        "dormant_opt_in": { "$ref": "#/$defs/DormantOptInCategory" },
        "deprecated": { "$ref": "#/$defs/DeprecatedCategory" }
      }
    },
    "enforcement_gaps_callout": {
      "type": "object",
      "description": "Documents that subsystem hooks are project-installed only; fresh projects without the config gate have ZERO subsystem-hook enforcement.",
      "additionalProperties": true,
      "properties": {
        "description": { "type": "string" },
        "subsystems": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "config_gates": { "type": "object", "additionalProperties": { "type": "string" } },
        "install_commands": { "type": "object", "additionalProperties": { "type": "string" } },
        "remediation": { "type": "string" }
      }
    },
    "see_also": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },

  "$defs": {
    "Trigger": {
      "description": "A Claude Code hook trigger. Either a single phase string (e.g. 'SessionStart', 'Stop', 'PreToolUse(Skill)', 'PostToolUse(Write|Edit|MultiEdit)') or an array of such strings for hooks registered on multiple phases (e.g. uiux-release-guard.js = ['PreToolUse(Skill)', 'Stop']).",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },

    "HookEntry": {
      "type": "object",
      "required": ["name", "trigger", "purpose"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Hook filename including extension (e.g. gsd-prompt-guard.js, gsd-validate-commit.sh)."
        },
        "trigger": { "$ref": "#/$defs/Trigger" },
        "purpose": { "type": "string", "minLength": 1 }
      }
    },

    "GlobalLiveCategory": {
      "type": "object",
      "description": "Hooks registered in ~/.claude/settings.json; fire on every session, no project config required.",
      "required": ["hooks"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "owner": { "type": "string" },
        "registered_in": { "type": "string" },
        "hooks": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/$defs/HookEntry" }
        }
      }
    },

    "ProjectInstalledCategory": {
      "type": "object",
      "description": "Config-gated hooks installed via subsystem SDK init; copied project-local and registered into <project>/.claude/settings.json by the shared installer.",
      "required": ["subsystems"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "scope": { "type": "string" },
        "installer": { "type": "string" },
        "settings_file": { "type": "string" },
        "hook_path_form": { "type": "string" },
        "subsystems": {
          "type": "object",
          "description": "Per-subsystem install entries. The four canonical subsystems are appsec / qa / uiux / discoverability.",
          "additionalProperties": false,
          "properties": {
            "appsec": { "$ref": "#/$defs/SubsystemInstallEntry" },
            "qa": { "$ref": "#/$defs/SubsystemInstallEntry" },
            "uiux": { "$ref": "#/$defs/SubsystemInstallEntry" },
            "discoverability": { "$ref": "#/$defs/SubsystemInstallEntry" }
          }
        }
      }
    },

    "SubsystemInstallEntry": {
      "type": "object",
      "required": ["config_gate", "snippet_path", "install_command", "hooks"],
      "additionalProperties": false,
      "properties": {
        "config_gate": {
          "type": "string",
          "minLength": 1,
          "description": "Config file whose presence enables the hooks. Without it, the hooks have no effect."
        },
        "snippet_path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the settings snippet that ships with this subsystem."
        },
        "install_command": {
          "type": "string",
          "minLength": 1,
          "description": "Command that installs (copies + merges) this subsystem's hooks into a project."
        },
        "hooks": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/$defs/HookEntry" }
        }
      }
    },

    "LibraryModulesCategory": {
      "type": "object",
      "description": "Shared helper modules imported by hook scripts at runtime; not hooks themselves, not registered in settings.json.",
      "required": ["modules"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "modules": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "required": ["name", "used_by"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "used_by": { "type": "string", "minLength": 1 },
              "path": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        }
      }
    },

    "DormantOptInCategory": {
      "type": "object",
      "description": "Hooks present on disk but intentionally not registered in settings.json; available for opt-in.",
      "required": ["entries"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "entries": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "required": ["name", "reason"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 },
              "path": { "type": "string" },
              "opt_in_via": { "type": "string" }
            }
          }
        }
      }
    },

    "DeprecatedCategory": {
      "type": "object",
      "description": "Hooks removed or renamed; listed so audit tools can flag legacy references.",
      "required": ["entries"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "entries": {
          "type": "array",
          "minItems": 0,
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "reason": { "type": "string" },
                  "replaced_by": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    }
  }
}
