{
  "_profile": "danger-off",
  "_doc": "危险操作关闭配置。显式 deny 所有高危 bash 操作：文件系统破坏、凭证访问、网络攻击工具、强推送、数据库重置。不设置 skipDangerousModePermissionPrompt（保持权限提示弹出）。不设置 allowBypassPermissions 相关标志。适合在不确定项目范围时作为基础安全底线，或在 CI/CD 环境中作为最小权限基线。",

  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf *)",
      "Bash(dd if=/dev/zero of=/dev/sd*)",
      "Bash(dd if=/dev/zero of=*)",
      "Bash(mkfs.* /dev/sd*)",
      "Bash(mkfs.*)",
      "Bash(shred *)",
      "Bash(wipefs *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(npm run db:reset *)",
      "Bash(npm run db:drop *)",
      "Bash(hydra *)",
      "Bash(medusa *)",
      "Bash(ncrack *)",
      "Bash(msfconsole *)",
      "Bash(msfvenom *)",
      "Bash(meterpreter *)",
      "Bash(sqlmap *)",
      "Bash(nikto *)",
      "Bash(wpscan *)",
      "Bash(masscan *)",
      "Bash(nmap *)",
      "Bash(zap-full-scan.py *)",
      "Bash(docker run *zaproxy*active*)",
      "Bash(docker run *zaproxy*full-scan*)",
      "Bash(ffuf -u http://*)",
      "Bash(dirsearch -u http://*)",
      "Bash(wfuzz *http://*)",
      "Bash(gobuster *http://*)",
      "Bash(beef-xss *)",
      "Bash(empire *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(socat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gcp/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(**/credentials)",
      "Read(**/credentials.json)",
      "Read(**/private*.pem)",
      "Read(**/private*.key)",
      "Read(**/server*.key)",
      "Read(**/secret*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.env)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gcp/**)",
      "Write(**/credentials)",
      "Write(**/credentials.json)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Bash(cat /etc/shadow*)",
      "Bash(cat /etc/passwd*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(curl *credentials*)",
      "Bash(curl * --data*@*)",
      "Bash(wget *credentials*)",
      "Bash(powershell *credentials*)",
      "Bash(powershell *.ssh*)",
      "Bash(powershell *EncodedCommand*)",
      "Bash(Get-Content ~/.aws/*)",
      "Bash(Get-Content ~/.ssh/*)"
    ]
  },

  "disableSkillShellExecution": true,

  "_danger_off_notes": [
    "skipDangerousModePermissionPrompt 明确不设置为 true（保持权限提示），这与 live settings.json 不同，是刻意的安全选择",
    "allowBypassPermissions 相关标志均不设置 (verify key name against your Claude Code version)",
    "nmap 加入 deny — 超出 authorized pentest ROE 范围的扫描",
    "git clean 系列加入 deny — 可能丢失未跟踪文件",
    "db:reset / db:drop 加入 deny — 破坏性数据库操作",
    "这是最小化 deny 列表，可按项目需要在 allow 中例外放行特定命令"
  ]
}
