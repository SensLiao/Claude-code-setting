{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "i2r/06-acceptance",
  "title": "I2R Acceptance (internal Gherkin G/W/T + external prose pass/fail)",
  "type": "object",
  "required": ["_meta", "scenarios"],
  "properties": {
    "_meta": { "$ref": "#/definitions/meta" },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "requirement_id", "scenario", "given", "when", "then", "prose"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[A-Z][A-Z0-9_]*-[0-9]{2,}-[0-9]{2,}$" },
          "requirement_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*-[0-9]{2,}$" },
          "scenario": { "type": "string" },
          "given": { "type": "array", "items": { "type": "string" } },
          "when": { "type": "array", "items": { "type": "string" } },
          "then": { "type": "array", "items": { "type": "string" } },
          "prose": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "required": ["artifact_version", "stage", "run_id", "generated_by_agent", "created_at"],
      "properties": {
        "artifact_version": { "type": "string" },
        "stage": { "type": "string" },
        "run_id": { "type": "string" },
        "generated_by_agent": { "type": "string" },
        "created_at": { "type": "string" },
        "input_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "sha256"],
            "properties": { "file": { "type": "string" }, "sha256": { "type": "string" } }
          }
        },
        "skills_used": { "type": "array", "items": { "type": "string" } },
        "tools_used": { "type": "array", "items": { "type": "string" } },
        "mode_context": { "type": "object" }
      }
    }
  }
}
