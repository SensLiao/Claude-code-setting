{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "i2r/05-nfr",
  "title": "I2R Non-Functional Requirements (ISO/IEC 25010:2023 + Volere fit_criterion)",
  "type": "object",
  "required": ["_meta", "nfrs"],
  "properties": {
    "_meta": { "$ref": "#/definitions/meta" },
    "nfrs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "iso25010_category", "coverage_status", "description", "priority", "source_ref"],
        "properties": {
          "id": { "type": "string", "pattern": "^NFR-[A-Z]+-[0-9]{2,}$" },
          "iso25010_category": {
            "type": "string",
            "enum": ["Functional Suitability", "Performance Efficiency", "Compatibility", "Interaction Capability", "Reliability", "Security", "Maintainability", "Flexibility", "Safety"]
          },
          "coverage_status": { "type": "string", "enum": ["required", "not_applicable", "deferred"] },
          "description": { "type": "string" },
          "fit_criterion": {
            "type": "object",
            "required": ["threshold", "environment", "period"],
            "properties": {
              "threshold": { "type": "string" },
              "environment": { "type": "string" },
              "period": { "type": "string" }
            }
          },
          "measurement_method": { "type": "string" },
          "priority": { "type": "string", "enum": ["MUST", "SHOULD", "COULD", "WONT"] },
          "source_ref": { "type": "string" },
          "source": { "type": "string", "enum": ["stated", "assumed", "decision"] },
          "na_reason": { "type": "string" },
          "deferred_missing_info": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "required": ["artifact_version", "stage", "run_id", "generated_by_agent", "created_at"],
      "properties": {
        "artifact_version": { "type": "string" },
        "stage": { "type": "string" },
        "run_id": { "type": "string" },
        "generated_by_agent": { "type": "string" },
        "created_at": { "type": "string" },
        "input_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "sha256"],
            "properties": { "file": { "type": "string" }, "sha256": { "type": "string" } }
          }
        },
        "skills_used": { "type": "array", "items": { "type": "string" } },
        "tools_used": { "type": "array", "items": { "type": "string" } },
        "mode_context": { "type": "object" }
      }
    }
  }
}
