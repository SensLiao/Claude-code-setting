{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "i2r/04-functional",
  "title": "I2R Functional Requirements (atomic EARS, one behaviour each)",
  "type": "object",
  "required": ["_meta", "requirements"],
  "properties": {
    "_meta": { "$ref": "#/definitions/meta" },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "capability", "ears_pattern", "system_name", "system_response", "rendered", "priority", "source", "source_ref", "acceptance_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*-[0-9]{2,}$" },
          "capability": { "type": "string" },
          "ears_pattern": { "type": "string", "enum": ["ubiquitous", "event_driven", "state_driven", "optional", "unwanted", "complex"] },
          "preconditions": { "type": "array", "items": { "type": "string" } },
          "trigger": { "type": "string" },
          "system_name": { "type": "string" },
          "system_response": { "type": "string" },
          "rendered": { "type": "string" },
          "priority": { "type": "string", "enum": ["MUST", "SHOULD", "COULD", "WONT"] },
          "source": { "type": "string", "enum": ["stated", "assumed", "decision"] },
          "source_ref": { "type": "string" },
          "rationale": { "type": "string" },
          "acceptance_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "required": ["artifact_version", "stage", "run_id", "generated_by_agent", "created_at"],
      "properties": {
        "artifact_version": { "type": "string" },
        "stage": { "type": "string" },
        "run_id": { "type": "string" },
        "generated_by_agent": { "type": "string" },
        "created_at": { "type": "string" },
        "input_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "sha256"],
            "properties": { "file": { "type": "string" }, "sha256": { "type": "string" } }
          }
        },
        "skills_used": { "type": "array", "items": { "type": "string" } },
        "tools_used": { "type": "array", "items": { "type": "string" } },
        "mode_context": { "type": "object" }
      }
    }
  }
}
