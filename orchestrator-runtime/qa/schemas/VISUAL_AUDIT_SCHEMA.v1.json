{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/VISUAL_AUDIT_SCHEMA.v1",
  "title": "Visual Regression Audit Output (per-surface fanout item)",
  "description": "Output of VisualAudit agent fanout item (commercial-cert only, R9 NEW). Runs Playwright toHaveScreenshot / Storybook visual diff against baseline. Consumed by deterministic VisualGate op.",
  "type": "object",
  "required": ["surface", "command_evidence", "baseline_present"],
  "properties": {
    "surface": {
      "type": "object",
      "required": ["path", "viewport"],
      "properties": {
        "path": { "type": "string" },
        "viewport": {
          "type": "object",
          "properties": {
            "width": { "type": "integer" },
            "height": { "type": "integer" },
            "dpr": { "type": "number" }
          }
        },
        "theme": { "type": "string", "enum": ["light", "dark", "auto", "n/a"] }
      }
    },
    "baseline_present": { "type": "boolean" },
    "baseline_hash": { "type": "string", "description": "sha256 of baseline image bytes for cache fingerprint" },
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command_id", "command", "exit_code", "stdout_path", "stdout_sha256", "parser_input", "parser_input_sha256", "parse_status"],
        "additionalProperties": false,
        "properties": {
          "command_id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "stdout_path": { "type": "string", "pattern": "^\\.qa/runs/[^\\\\/]+/raw/[^\\\\/]+\\.stdout$" },
          "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stderr_path": { "type": "string" },
          "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "artifact_path": { "type": "string" },
          "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parser": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+@[0-9]+$" },
          "parser_input": { "type": "string", "enum": ["artifact", "stdout", "stderr"] },
          "parser_input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parse_status": { "type": "string", "enum": ["OK", "PARSER_FAILED", "INPUT_MISSING", "SKIPPED"] },
          "parsed_metrics": { "type": ["object", "null"] },
          "git_head": { "type": "string" },
          "git_dirty_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "captured_by": { "type": "string" }
        },
        "allOf": [
          { "if": { "properties": { "parser_input": { "const": "artifact" } } }, "then": { "required": ["artifact_path", "artifact_sha256"] } },
          { "if": { "properties": { "parse_status": { "const": "OK" } } }, "then": { "required": ["parser", "parsed_metrics"], "properties": { "parsed_metrics": { "type": "object" } } } }
        ]
      }
    },
    "pixel_diff_count": { "type": "integer", "minimum": 0 },
    "pixel_diff_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "artifacts": {
      "type": "object",
      "properties": {
        "actual_png": { "type": "string" },
        "expected_png": { "type": "string" },
        "diff_png": { "type": "string" }
      }
    },
    "decision_hint": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] }
  }
}
