{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/CONTRACT_TEST_SCHEMA.v1",
  "title": "Per-Contract API/Event Test Output",
  "description": "Output of a single Contract subset of ComponentOrContract fanout item. One per changed API contract.",
  "type": "object",
  "required": ["api_or_event", "schema_source", "command_evidence", "decision"],
  "properties": {
    "api_or_event": {
      "type": "object",
      "required": ["identifier", "kind"],
      "properties": {
        "identifier": { "type": "string", "description": "e.g. POST /api/checkout or event:order.created" },
        "kind": { "type": "string", "enum": ["rest", "graphql", "rpc", "event", "websocket"] }
      }
    },
    "schema_source": {
      "type": "object",
      "required": ["kind", "path"],
      "properties": {
        "kind": { "type": "string", "enum": ["openapi", "graphql-sdl", "pact", "asyncapi", "protobuf", "json-schema"] },
        "path": { "type": "string" }
      }
    },
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command_id", "command", "exit_code", "stdout_path", "stdout_sha256", "parser_input", "parser_input_sha256", "parse_status"],
        "additionalProperties": false,
        "properties": {
          "command_id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "stdout_path": { "type": "string", "pattern": "^\\.qa/runs/[^\\\\/]+/raw/[^\\\\/]+\\.stdout$" },
          "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stderr_path": { "type": "string" },
          "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "artifact_path": { "type": "string" },
          "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parser": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+@[0-9]+$" },
          "parser_input": { "type": "string", "enum": ["artifact", "stdout", "stderr"] },
          "parser_input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parse_status": { "type": "string", "enum": ["OK", "PARSER_FAILED", "INPUT_MISSING", "SKIPPED"] },
          "parsed_metrics": { "type": ["object", "null"] },
          "git_head": { "type": "string" },
          "git_dirty_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "captured_by": { "type": "string" }
        },
        "allOf": [
          { "if": { "properties": { "parser_input": { "const": "artifact" } } }, "then": { "required": ["artifact_path", "artifact_sha256"] } },
          { "if": { "properties": { "parse_status": { "const": "OK" } } }, "then": { "required": ["parser", "parsed_metrics"], "properties": { "parsed_metrics": { "type": "object" } } } }
        ]
      }
    },
    "drift_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "location"],
        "properties": {
          "kind": { "type": "string", "enum": ["added", "removed", "type-changed", "required-changed", "enum-shrunk", "incompatible"] },
          "location": { "type": "string" },
          "before": { "type": "string" },
          "after": { "type": "string" }
        }
      }
    },
    "breaking_changes": { "type": "integer", "minimum": 0 },
    "decision": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "CONDITIONAL_PASS", "MISSING"]
    },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  }
}
