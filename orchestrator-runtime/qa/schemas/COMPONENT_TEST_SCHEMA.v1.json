{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/COMPONENT_TEST_SCHEMA.v1",
  "title": "Per-Surface Component Test Output",
  "description": "Output of a single UnitOrComponent / ComponentOrContract fanout item. One per changed surface.",
  "type": "object",
  "required": ["surface", "command_evidence", "decision"],
  "properties": {
    "surface": {
      "type": "object",
      "required": ["path", "kind"],
      "properties": {
        "path": { "type": "string" },
        "kind": { "type": "string", "enum": ["component", "hook", "module", "service", "endpoint"] }
      }
    },
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cmd", "exit_code"],
        "properties": {
          "cmd": { "type": "string" },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" },
          "exit_code": { "type": "integer" },
          "duration_ms": { "type": "integer" }
        }
      }
    },
    "passed": { "type": "integer", "minimum": 0 },
    "failed": { "type": "integer", "minimum": 0 },
    "skipped": { "type": "integer", "minimum": 0 },
    "coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "decision": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "CONDITIONAL_PASS", "MISSING"]
    },
    "failure_samples": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
    "artifacts": {
      "type": "array",
      "items": { "type": "string", "description": "Relative paths under .qa/evidence/<tag>/component/<surface_id>/" }
    }
  }
}
