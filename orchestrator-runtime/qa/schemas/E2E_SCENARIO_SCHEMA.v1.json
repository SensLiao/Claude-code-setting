{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/E2E_SCENARIO_SCHEMA.v1",
  "title": "Single E2E Scenario Output",
  "description": "Output of one E2E pipeline stage (prepare or run-validate). Per-scenario evidence captured by e2e-runner (Playwright / Vercel Agent Browser).",
  "type": "object",
  "required": ["scenario_id", "stage", "command_evidence", "decision"],
  "properties": {
    "scenario_id": { "type": "string" },
    "journey": { "type": "string" },
    "stage": { "type": "string", "enum": ["prepare", "run-validate"] },
    "target_url": { "type": "string" },
    "viewport": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "dpr": { "type": "number" }
      }
    },
    "branch_sha": { "type": "string" },
    "playwright_config_hash": { "type": "string" },
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command_id", "command", "exit_code", "stdout_path", "stdout_sha256", "parser_input", "parser_input_sha256", "parse_status"],
        "additionalProperties": false,
        "properties": {
          "command_id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "stdout_path": { "type": "string", "pattern": "^\\.qa/runs/[^\\\\/]+/raw/[^\\\\/]+\\.stdout$" },
          "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stderr_path": { "type": "string" },
          "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "artifact_path": { "type": "string" },
          "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parser": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+@[0-9]+$" },
          "parser_input": { "type": "string", "enum": ["artifact", "stdout", "stderr"] },
          "parser_input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parse_status": { "type": "string", "enum": ["OK", "PARSER_FAILED", "INPUT_MISSING", "SKIPPED"] },
          "parsed_metrics": { "type": ["object", "null"] },
          "git_head": { "type": "string" },
          "git_dirty_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "captured_by": { "type": "string" }
        },
        "allOf": [
          { "if": { "properties": { "parser_input": { "const": "artifact" } } }, "then": { "required": ["artifact_path", "artifact_sha256"] } },
          { "if": { "properties": { "parse_status": { "const": "OK" } } }, "then": { "required": ["parser", "parsed_metrics"], "properties": { "parsed_metrics": { "type": "object" } } } }
        ]
      }
    },
    "retry_count": { "type": "integer", "minimum": 0 },
    "flaky_signal": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "enum": ["retry_pass", "ci_only_fail", "nondeterministic_fail", "none"] },
        "evidence": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "screenshot": { "type": "string" },
        "video": { "type": "string" },
        "trace": { "type": "string" },
        "har": { "type": "string" }
      }
    },
    "decision": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "CONDITIONAL_PASS", "MISSING"]
    }
  }
}
