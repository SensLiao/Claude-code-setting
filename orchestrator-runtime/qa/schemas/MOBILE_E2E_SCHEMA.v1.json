{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/MOBILE_E2E_SCHEMA.v1",
  "title": "Mobile-native E2E Runner Output",
  "description": "Output of qa-mobile-e2e-runner agent (CAPABILITY-UPGRADE Wave A, Q3 — DORMANT/备选). Runs Maestro YAML flows on emulator/simulator (real device optional) ONLY when a real mobile-app marker is detected; emits NOT_APPLICABLE on pure web/backend projects (the correct, honest outcome — not a defect). Consumed by enterprise-qa-testing Mobile E2E layer (§4). decision_hint is a draft — the parent skill / deterministic gate makes the final call.",
  "type": "object",
  "required": ["command_evidence", "activation", "decision_hint"],
  "properties": {
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "description": "Mandatory when activated (min 1 entry). EXEMPT when decision_hint == NOT_APPLICABLE — the activation gate ran nothing by design.",
      "items": {
        "type": "object",
        "required": ["command_id", "command", "exit_code", "stdout_path", "stdout_sha256", "parser_input", "parser_input_sha256", "parse_status"],
        "additionalProperties": false,
        "properties": {
          "command_id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "stdout_path": { "type": "string", "pattern": "^\\.qa/runs/[^\\\\/]+/raw/[^\\\\/]+\\.stdout$" },
          "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stderr_path": { "type": "string" },
          "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "artifact_path": { "type": "string" },
          "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parser": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+@[0-9]+$" },
          "parser_input": { "type": "string", "enum": ["artifact", "stdout", "stderr"] },
          "parser_input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parse_status": { "type": "string", "enum": ["OK", "PARSER_FAILED", "INPUT_MISSING", "SKIPPED"] },
          "parsed_metrics": { "type": ["object", "null"] },
          "git_head": { "type": "string" },
          "git_dirty_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "captured_by": { "type": "string" }
        },
        "allOf": [
          { "if": { "properties": { "parser_input": { "const": "artifact" } } }, "then": { "required": ["artifact_path", "artifact_sha256"] } },
          { "if": { "properties": { "parse_status": { "const": "OK" } } }, "then": { "required": ["parser", "parsed_metrics"], "properties": { "parsed_metrics": { "type": "object" } } } }
        ]
      }
    },
    "activation": {
      "type": "object",
      "required": ["mobile_marker_found"],
      "properties": {
        "mobile_marker_found": { "type": "boolean", "description": "no marker => decision_hint NOT_APPLICABLE; never force a mobile test on web/backend" },
        "platform": { "type": "string", "enum": ["android", "ios", "react-native", "flutter", "unknown"] },
        "marker_evidence": { "type": "string", "description": "e.g. pubspec.yaml flutter: + android/" }
      }
    },
    "tool": { "type": "string", "enum": ["maestro"] },
    "device": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["emulator", "simulator", "real-device"] },
        "identifier": { "type": "string", "description": "e.g. Pixel_7_API_34" }
      }
    },
    "flows_run": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flow_file", "result"],
        "properties": {
          "flow_file": { "type": "string" },
          "result": { "type": "string", "enum": ["pass", "fail", "skipped"] },
          "selector_strategy": { "type": "string", "description": "prefer id / text / accessibility-id; raw coordinate taps flagged FRAGILE_SELECTOR in notes" }
        }
      }
    },
    "assertions": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": { "type": "array", "items": { "type": "string" }, "description": "Maestro --debug-output: screenshots + view hierarchy on failure" },
    "flakiness_note": { "type": ["string", "null"], "description": "retry-pass is NOT a clean PASS; set this so the parent routes it to qa-flaky-governance" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "decision_hint": { "type": "string", "enum": ["PASS", "WARN", "FAIL", "BLOCKED", "NOT_APPLICABLE"], "description": "Agent's draft assessment; parent skill / deterministic gate makes final decision. Non-mobile project => NOT_APPLICABLE, never PASS/FAIL; tool_missing => BLOCKED." }
  }
}
