{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/RISK_CLASSIFY_SCHEMA.v1",
  "title": "QA Risk Classifier Output",
  "description": "Output of qa-risk-classifier agent. Per reviewer R4 Option A, invoked by Skill main thread BEFORE preview/workflow launch. Result is embedded into spec.context.risk_snapshot AND used for mode selection.",
  "type": "object",
  "required": ["final_level", "floor_rule_status", "impact_score", "likelihood_score", "modifier_attribution", "evidence_confidence"],
  "properties": {
    "final_level": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"],
      "description": "Computed via Impact × Likelihood + Modifier Cap, then promoted by §3.6 Floor Rules if applicable."
    },
    "floor_rule_status": {
      "type": "object",
      "required": ["triggered"],
      "properties": {
        "triggered": { "type": "boolean" },
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path_category", "evidence_ref"],
            "properties": {
              "path_category": {
                "type": "string",
                "enum": ["auth", "payment", "privacy", "safety", "destructive", "regulatory", "cross_tenant_data", "admin", "billing", "checkout", "signup", "data_export"]
              },
              "evidence_ref": { "type": "string" },
              "mandated_layers": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "impact_score": { "type": "integer", "minimum": 1, "maximum": 5 },
    "likelihood_score": { "type": "integer", "minimum": 1, "maximum": 5 },
    "modifier_attribution": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["modifier", "magnitude", "rationale"],
        "properties": {
          "modifier": { "type": "string", "description": "Per enterprise-qa-testing §3.4 Exposure Modifier names" },
          "magnitude": { "type": "integer" },
          "rationale": { "type": "string" }
        }
      }
    },
    "modifier_cap_applied": { "type": "boolean", "description": "True if raw modifier sum exceeded +10 cap" },
    "evidence_confidence": {
      "type": "string",
      "enum": ["High", "Medium", "Low"],
      "description": "Confidence in the classification given available signals"
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "snippet"],
        "properties": {
          "file": { "type": "string" },
          "lines": { "type": "string" },
          "snippet": { "type": "string" }
        }
      }
    }
  }
}
