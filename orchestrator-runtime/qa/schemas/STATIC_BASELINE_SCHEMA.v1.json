{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qa/STATIC_BASELINE_SCHEMA.v1",
  "title": "Static Baseline Runner Output",
  "description": "Output of StaticBaseline agent node. Runs tsc + ESLint + Prettier + npm audit + git-secrets against changed files. Consumed by deterministic StaticGate op.",
  "type": "object",
  "required": ["command_evidence", "tsc_errors", "eslint_findings", "npm_audit_critical_count", "git_secrets_hits"],
  "properties": {
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command_id", "command", "exit_code", "stdout_path", "stdout_sha256", "parser_input", "parser_input_sha256", "parse_status"],
        "additionalProperties": false,
        "properties": {
          "command_id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "started_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "stdout_path": { "type": "string", "pattern": "^\\.qa/runs/[^\\\\/]+/raw/[^\\\\/]+\\.stdout$" },
          "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "stderr_path": { "type": "string" },
          "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "artifact_path": { "type": "string" },
          "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parser": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+@[0-9]+$" },
          "parser_input": { "type": "string", "enum": ["artifact", "stdout", "stderr"] },
          "parser_input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "parse_status": { "type": "string", "enum": ["OK", "PARSER_FAILED", "INPUT_MISSING", "SKIPPED"] },
          "parsed_metrics": { "type": ["object", "null"] },
          "git_head": { "type": "string" },
          "git_dirty_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "captured_by": { "type": "string" }
        },
        "allOf": [
          { "if": { "properties": { "parser_input": { "const": "artifact" } } }, "then": { "required": ["artifact_path", "artifact_sha256"] } },
          { "if": { "properties": { "parse_status": { "const": "OK" } } }, "then": { "required": ["parser", "parsed_metrics"], "properties": { "parsed_metrics": { "type": "object" } } } }
        ]
      }
    },
    "tsc_errors": { "type": "integer", "minimum": 0 },
    "tsc_error_samples": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
    "eslint_findings": {
      "type": "object",
      "properties": {
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "samples": { "type": "array", "items": { "type": "string" }, "maxItems": 20 }
      }
    },
    "prettier_drift_files": { "type": "array", "items": { "type": "string" } },
    "npm_audit_critical_count": { "type": "integer", "minimum": 0 },
    "npm_audit_high_count": { "type": "integer", "minimum": 0 },
    "npm_audit_advisories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "package"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "moderate", "low", "info"] },
          "package": { "type": "string" }
        }
      }
    },
    "git_secrets_hits": { "type": "integer", "minimum": 0 },
    "git_secrets_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "redacted_match"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "redacted_match": { "type": "string", "description": "REDACTED; raw secret never emitted per security.md" }
        }
      }
    },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  }
}
