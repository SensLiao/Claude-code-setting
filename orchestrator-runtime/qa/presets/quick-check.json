{
  "engine_version": "1.0",
  "orchestrator": "qa",
  "domain_runtime_version": "qa-0.1.0",
  "preset_name": "quick-check",
  "mode": "quick-check",
  "_doc_ref": "QA-PHASE-B-BLUEPRINT.md §1 quick-check + §2 mode selection + §22 R4/R5",
  "_when": "PR on feature branch / dev push / changed_lines < 50 / no critical_path touched / no API contract changed / no component-behavior surface changed / no testable user-facing behavior changed (R5)",
  "context": {
    "_skill_fills": [
      "risk_snapshot (per R4)",
      "release_tag",
      "run_id",
      "critical_release_paths",
      "policy"
    ]
  },
  "phases": [
    {
      "name": "LayerSelect",
      "type": "single",
      "model": "balanced",
      "resolved_model": "sonnet",
      "agentType": "qa-risk-classifier",
      "prompt_ref": "layer-select.v1",
      "schema_ref": "LAYER_SELECT_SCHEMA.v1",
      "stall_ms": 180000,
      "timeout_policy": "default_short_classification"
    },
    {
      "name": "StaticBaseline",
      "type": "single",
      "model": "balanced",
      "resolved_model": "sonnet",
      "agentType": "qa-static-baseline-runner",
      "prompt_ref": "static-baseline.v1",
      "schema_ref": "STATIC_BASELINE_SCHEMA.v1",
      "stall_ms": 600000,
      "timeout_policy": "static_baseline_external_commands"
    },
    {
      "name": "StaticGate",
      "type": "deterministic",
      "op": "run_static_baseline_policy"
    },
    {
      "name": "Gate",
      "type": "deterministic",
      "op": "qa_gate_policy"
    },
    {
      "name": "EvidenceBundle",
      "type": "single",
      "model": "balanced",
      "resolved_model": "sonnet",
      "agentType": "qa-evidence-validator",
      "prompt_ref": "evidence-bundle.v1",
      "schema_ref": "EVIDENCE_BUNDLE_SCHEMA.v1",
      "stall_ms": 300000,
      "post_invariants": [
        "ensure_evidence_bundle_layers"
      ]
    }
  ],
  "prompts": {},
  "schemas": {},
  "ops_allowed": {
    "deterministic": [
      "run_static_baseline_policy",
      "qa_gate_policy"
    ],
    "predicates": [
      "no_layers_active",
      "evidence_bundle_incomplete"
    ],
    "invariants": [
      "ensure_evidence_bundle_layers"
    ]
  },
  "_estimate": {
    "token_estimate_low": 30000,
    "token_estimate_high": 80000,
    "hard_budget_cap": 100000,
    "wallclock_estimate_minutes": 2,
    "evidence_layers": [
      ".qa/evidence/<tag>/02-layer-selection.yaml",
      ".qa/evidence/<tag>/static.yaml",
      ".qa/evidence/<tag>/qa_evidence_bundle.yaml",
      ".qa/evidence/<tag>/workflow-state.yaml"
    ]
  }
}
