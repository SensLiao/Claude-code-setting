{
  "engine_version": "1.0",
  "orchestrator": "qa",
  "domain_runtime_version": "qa-0.1.0",
  "preset_name": "release-readiness",
  "mode": "release-readiness",
  "_doc_ref": "QA-PHASE-B-BLUEPRINT.md §1 release-readiness + §22.2 R2 roadmap (dedicated runners before this ships)",
  "_when": "release_tag matches /^v\\d+\\.\\d+\\.\\d+/ AND not pre-release suffix / staging->prod / user explicit",
  "_d1_caveat": "Per D1 lock + R2 roadmap: this preset uses code-reviewer for fanout workers in v0.1.0. BEFORE any project sets execution_mode=workflow-spec AND uses this preset, the R2 dedicated runner agents (qa-static-baseline-runner / qa-component-runner / qa-contract-runner) MUST be written.",
  "context": {
    "_skill_fills": [
      "risk_snapshot (per R4)",
      "release_tag",
      "run_id",
      "critical_release_paths",
      "policy"
    ]
  },
  "phases": [
    {
      "name": "LayerSelect",
      "type": "single",
      "model": "strongest_available",
      "resolved_model": "opus",
      "agentType": "qa-risk-classifier",
      "prompt_ref": "layer-select.v1",
      "schema_ref": "LAYER_SELECT_SCHEMA.v1",
      "stall_ms": 180000
    },
    {
      "name": "StaticBaseline",
      "type": "single",
      "model": "balanced",
      "resolved_model": "sonnet",
      "agentType": "qa-static-baseline-runner",
      "prompt_ref": "static-baseline.v1",
      "schema_ref": "STATIC_BASELINE_SCHEMA.v1",
      "stall_ms": 600000
    },
    {
      "name": "StaticGate",
      "type": "deterministic",
      "op": "run_static_baseline_policy"
    },
    {
      "name": "ComponentOrContract",
      "type": "fanout",
      "items_from": "state.LayerSelect.changed_surfaces",
      "_width_range": [
        3,
        6
      ],
      "_dispatch_note": "qa-component-runner dual-handles component + api-contract kinds via component-or-contract.v1 prompt's _dispatched_schema routing field. Future R2 follow-up: pure split into separate Component + Contract phases with dedicated qa-component-runner / qa-contract-runner.",
      "model": "balanced",
      "resolved_model": "sonnet",
      "agentType": "qa-component-runner",
      "prompt_ref": "component-or-contract.v1",
      "schema_ref": "COMPONENT_TEST_SCHEMA.v1",
      "stall_ms": 600000
    },
    {
      "name": "E2E",
      "type": "pipeline",
      "items_from": "state.LayerSelect.critical_scenarios",
      "_items_range": [
        1,
        3
      ],
      "stages": [
        {
          "name": "prepare",
          "type": "single",
          "model": "balanced",
          "resolved_model": "sonnet",
          "agentType": "e2e-runner",
          "prompt_ref": "e2e-scenario-prepare.v1",
          "schema_ref": "E2E_SCENARIO_SCHEMA.v1",
          "stall_ms": 300000
        },
        {
          "name": "run-validate",
          "type": "single",
          "model": "strongest_available",
          "resolved_model": "opus",
          "agentType": "e2e-runner",
          "prompt_ref": "e2e-scenario.v1",
          "schema_ref": "E2E_SCENARIO_SCHEMA.v1",
          "stall_ms": 900000,
          "timeout_policy": "long_running_external_test"
        }
      ]
    },
    {
      "name": "FlakyTriage",
      "type": "single",
      "skip_if": "no_flaky_signal",
      "model": "strongest_available",
      "resolved_model": "opus",
      "agentType": "qa-flaky-triager",
      "prompt_ref": "flaky-triage.v1",
      "schema_ref": "FLAKY_TRIAGE_SCHEMA.v1",
      "stall_ms": 300000,
      "post_invariants": [
        "critical_release_paths_have_owner"
      ]
    },
    {
      "name": "FlakyQuarantineCheck",
      "type": "deterministic",
      "op": "flaky_quarantine_decision"
    },
    {
      "name": "Gate",
      "type": "deterministic",
      "op": "qa_gate_policy"
    },
    {
      "name": "EvidenceBundle",
      "type": "single",
      "model": "strongest_available",
      "resolved_model": "opus",
      "agentType": "qa-evidence-validator",
      "prompt_ref": "evidence-bundle.v1",
      "schema_ref": "EVIDENCE_BUNDLE_SCHEMA.v1",
      "stall_ms": 300000,
      "post_invariants": [
        "ensure_evidence_bundle_layers",
        "map_null_outputs_to_missing"
      ]
    }
  ],
  "prompts": {},
  "schemas": {},
  "ops_allowed": {
    "deterministic": [
      "run_static_baseline_policy",
      "qa_gate_policy",
      "compute_critical_path_coverage",
      "flaky_quarantine_decision"
    ],
    "predicates": [
      "no_layers_active",
      "critical_path_not_covered",
      "evidence_bundle_incomplete",
      "no_flaky_signal",
      "fanout_item_dropped"
    ],
    "invariants": [
      "ensure_evidence_bundle_layers",
      "map_null_outputs_to_missing",
      "critical_release_paths_have_owner"
    ]
  },
  "_estimate": {
    "token_estimate_low": 300000,
    "token_estimate_high": 800000,
    "hard_budget_cap": 1000000,
    "wallclock_estimate_minutes": 12,
    "evidence_layers": [
      ".qa/evidence/<tag>/02-layer-selection.yaml",
      ".qa/evidence/<tag>/static.yaml",
      ".qa/evidence/<tag>/component.yaml",
      ".qa/evidence/<tag>/contract.yaml",
      ".qa/evidence/<tag>/e2e.yaml",
      ".qa/evidence/<tag>/flaky_triage.yaml",
      ".qa/evidence/<tag>/qa_evidence_bundle.yaml",
      ".qa/evidence/<tag>/workflow-state.yaml",
      ".qa/evidence/<tag>/dispatch_failures.yaml"
    ]
  }
}
