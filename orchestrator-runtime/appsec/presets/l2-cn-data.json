{
  "engine_version": "1.0",
  "orchestrator": "appsec",
  "phases": [
    {
      "name": "Scope",
      "type": "single",
      "model": "strongest_available",
      "agentType": "appsec-risk-classifier",
      "prompt_ref": "scope.v1",
      "schema_ref": "SCOPE_SCHEMA.v1"
    },
    {
      "name": "Plan",
      "type": "single",
      "model": "strongest_available",
      "agentType": "appsec-risk-classifier",
      "prompt_ref": "plan.v1",
      "schema_ref": "PLAN_SCHEMA.v1",
      "post_invariants": [
        "ensure_csf_coverage"
      ]
    },
    {
      "name": "Find",
      "type": "fanout",
      "items_from": "state.Plan.selected_finders",
      "model": "balanced",
      "agentType": "appsec-reviewer",
      "prompt_ref": "find.v1",
      "schema_ref": "FIND_SCHEMA.v1"
    },
    {
      "name": "Normalize",
      "type": "single",
      "model": "balanced",
      "agentType": "appsec-finding-triager",
      "prompt_ref": "normalize.v1",
      "schema_ref": "NORMALIZE_SCHEMA.v1",
      "skip_if": "no_candidates",
      "skip_default": {
        "findings": []
      }
    },
    {
      "name": "Dedup",
      "type": "deterministic",
      "op": "fingerprint_cluster"
    },
    {
      "name": "Verify",
      "type": "pipeline",
      "items_from": "state.Dedup.eligible_clusters",
      "stages": [
        {
          "type": "fanout",
          "model": "balanced",
          "agentType": "appsec-finding-triager",
          "prompt_ref": "verify.v1",
          "schema_ref": "VOTE_SCHEMA.v1",
          "vote_count_by_severity": {
            "low": 1,
            "medium": 1,
            "high": 3,
            "critical": 3
          }
        }
      ]
    },
    {
      "name": "Map",
      "type": "single",
      "model": "balanced",
      "agentType": "appsec-finding-triager",
      "prompt_ref": "map.v1",
      "schema_ref": "MAP_SCHEMA.v1",
      "skip_if": "no_accepted",
      "skip_default": {
        "findings": []
      }
    },
    {
      "name": "Gate",
      "type": "deterministic",
      "op": "appsec_gate_policy"
    },
    {
      "name": "Synthesize",
      "type": "single",
      "model": "balanced",
      "agentType": "appsec-evidence-validator",
      "prompt_ref": "synthesize.v1",
      "schema_ref": "SYNTH_SCHEMA.v1"
    },
    {
      "name": "PersistEvidence",
      "type": "single",
      "model": "balanced",
      "agentType": "appsec-evidence-validator",
      "prompt_ref": "persist-evidence.v1",
      "schema_ref": "PERSIST_SCHEMA.v1",
      "sdk": {
        "command": "appsec-sdk evidence.append",
        "layer": "workflow-state"
      }
    },
    {
      "name": "PersistCnDataOverlay",
      "type": "single",
      "model": "balanced",
      "agentType": "appsec-evidence-validator",
      "prompt_ref": "persist-evidence.v1",
      "schema_ref": "PERSIST_SCHEMA.v1",
      "sdk": {
        "command": "appsec-sdk overlay.activate",
        "layer": "overlay-cn_data"
      }
    }
  ],
  "prompts": {},
  "schemas": {},
  "ops_allowed": {
    "deterministic": [
      "fingerprint_cluster",
      "appsec_gate_policy",
      "compute_recall"
    ],
    "predicates": [
      "no_candidates",
      "no_accepted"
    ],
    "invariants": [
      "ensure_csf_coverage",
      "prune_below_floor"
    ]
  },
  "_estimate": {
    "token_estimate_low": 320000,
    "token_estimate_high": 850000,
    "hard_budget_cap": 1000000,
    "wallclock_estimate_minutes": 13,
    "evidence_layers": [
      ".appsec/evidence/<tag>/threat-model/",
      ".appsec/evidence/<tag>/sca/",
      ".appsec/evidence/<tag>/secret-scan/",
      ".appsec/evidence/<tag>/sast/",
      ".appsec/evidence/<tag>/code-review/",
      ".appsec/evidence/<tag>/headers-cookies/",
      ".appsec/decisions/<tag>/appsec_release_decision.yaml",
      ".appsec/evidence/<tag>/overlay-cn_data/checklist.yaml"
    ]
  }
}
