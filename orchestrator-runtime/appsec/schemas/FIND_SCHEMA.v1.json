{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "FIND_SCHEMA.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finder_key",
    "candidate_findings"
  ],
  "properties": {
    "finder_key": {
      "type": "string",
      "minLength": 1
    },
    "candidate_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "severity_guess",
          "file"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity_guess": {
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "oracle_ref": {
            "type": "string"
          }
        }
      }
    }
  }
}
