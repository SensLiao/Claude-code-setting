schema_version: 1.1
release_tag: REPLACE_WITH_RELEASE_TAG
intent: multi-surface   # single-surface | multi-surface — decides whether the completeness ledger is REQUIRED (multi → REQUIRED; single may omit)
surfaces:
  - id: REPLACE_WITH_SURFACE_ID
    surface_type: marketing   # marketing | dashboard | settings | auth | onboarding | error | empty | payment | admin
    route: "/"
    breakpoints: [320, 768, 1024, 1440]
    states: [default, loading, error, empty]
    a11y_critical: true
    design_pass_skill: null
    evidence_path: null
    build_status: pending     # pending | built | failed — set by P3 BUILD fan-out loop; failed must be surfaced to user, never silently dropped
    review_status: pending    # pending | reviewed-pass | reviewed-fail — set by P5 REVIEW per-surface coverage loop
    audit_status: pending     # pending | designed | audited-pass | audited-fail
    data_classes: []   # for AppSec handoff: [credentials, session, PII, email, payment]
