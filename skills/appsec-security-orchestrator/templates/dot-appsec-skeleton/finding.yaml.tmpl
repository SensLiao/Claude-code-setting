# AppSec finding template (schema v1.0)
# Canonical: ~/.claude/skills/appsec-security-orchestrator/SKILL.md §9
# Write path: `appsec-sdk finding.add < this-file.yaml`  (direct Write blocked by hook §18.5a)

schema_version: 1.0
id: 2026-05-25-sast-001                # <YYYY-MM-DD>-<source>-<seq>
source: sast                            # sast | dast | sca | secret_scan | manual_review | pentest | external_disclosure | threat_model | iac_scan | container_scan | cloud_posture | secrets_engineering
detector: semgrep@1.50.0                # tool name + version
severity: high                          # critical | high | medium | low
confidence: medium                      # high | medium | low

# **ASVS 5.0 version-pinned identifiers ONLY**. Regex: ^v5\.0\.0-\d+\.\d+\.\d+$
# ASVS 4.x identifiers (V2.1.1 etc.) are hard-rejected by sdk + PreToolUse hook §18.5a.
asvs_mapping:
  - v5.0.0-6.2.1
  - v5.0.0-2.3.4

csf_function: PR                        # GV | ID | PR | DE | RS | RC
cwe: [CWE-798]
# OWASP Top 10:2025 IDs (A<n>:2025). 2025 replaced 2021 as the primary Top 10
# (primary-source verified 2026-06-05). Canonical id list + 2021→2025 crosswalk:
# references/standards-and-mappings.md §6.5 + references/standards-crosswalk.json.
# A07:2025 = Authentication Failures (same A07 as 2021). NB Injection moved A03:2021 → A05:2025;
# Software Supply Chain Failures = A03:2025. Legacy A<n>:2021 labels remain accepted (not hard-cut).
owasp_top10: [A07:2025]
api_top10: []                           # populate if API finding

affected:
  files:
    - src/config/database.ts:42
  components:
    - backend/auth
  data_classes:
    - confidential

exploit_likelihood: medium              # high | medium | low | theoretical
business_impact: high                   # high | medium | low
computed_risk: high                     # critical | high | medium | low

description: >
  Database password hardcoded in source. Detected by semgrep rule
  "generic.secrets.security.detected-generic-secret".

reproduction_steps: |
  1. Open src/config/database.ts
  2. Observe `password: "<REDACTED:credential>"` literal
  (NEVER include raw secret values here — pipe through `appsec-sdk redact` first;
   sdk will reject finding.add if raw secret pattern detected.)

evidence:
  log_excerpt: "<REDACTED:credential>"
  screenshot: null
  test_output: .appsec/evidence/<tag>/sast/raw.json

remediation:
  immediate_mitigation: rotate the credential and remove the literal
  permanent_fix: |
    1. Move secret to `.env` (gitignored) read via process.env at startup
    2. Add startup validator that fails fast if env var missing
    3. Add a SAST guard rule blocking re-introduction of literal credentials
  regression_test_needed: yes

owner: backend-team
sla_due: 2026-06-01
status: open                            # open | in_progress | mitigated | resolved | accepted
verification_status: pending            # pending | red_confirmed | fix_applied | green_confirmed | regression_in_ci
test_commands:
  - npm test -- --grep "env-validation"
  - npm run sast

