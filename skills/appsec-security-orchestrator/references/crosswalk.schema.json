{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness.local/standards-crosswalk/crosswalk.schema.json",
  "title": "Standards Crosswalk",
  "description": "Machine-readable cross-mapping index linking AppSec/QA/UX standards. Human-curated, live-verified, do not auto-refresh.",
  "type": "object",
  "additionalProperties": true,
  "required": ["crosswalk_version", "generated_for", "do_not_auto_refresh", "standards", "crosswalk"],
  "properties": {
    "crosswalk_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_for": { "type": "string", "minLength": 1 },
    "do_not_auto_refresh": { "type": "boolean", "const": true },
    "governance": { "type": "object" },
    "standards": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/standard" }
    },
    "crosswalk": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping" }
    }
  },
  "$defs": {
    "verified_on": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source": {
      "type": "string",
      "pattern": "^https?://",
      "minLength": 8
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "source", "verified_on", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source": { "$ref": "#/$defs/source" },
        "verified_on": { "$ref": "#/$defs/verified_on" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/item" }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "asvs": { "type": "string", "minLength": 1 },
        "owasp_top10_2025": { "type": "string", "minLength": 1 },
        "owasp_llm": { "type": "string", "minLength": 1 },
        "owasp_asi": { "type": "string", "minLength": 1 },
        "cwe_family": { "type": "string", "minLength": 1 },
        "csf": { "type": "string", "minLength": 1 },
        "ssdf": { "type": "string", "minLength": 1 },
        "iso25010": { "type": "string", "minLength": 1 },
        "wcag": { "type": "string", "minLength": 1 }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "links", "confidence", "source", "verified_on"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "links": { "$ref": "#/$defs/links" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "note": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "verified_on": { "$ref": "#/$defs/verified_on" }
      }
    }
  }
}
